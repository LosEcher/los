{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "TEST_DATABASE_URL", "LOS_ALLOW_LIVE_TEST_DB", "LOS_TEST_RUN_ID", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
