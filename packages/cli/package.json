{
  "name": "@los/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "los": "./dist/index.js",
    "los-mcp": "./dist/mcp-entry.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js dist/mcp-entry.js",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test --experimental-test-coverage '--test-coverage-include=src/**/*.ts' src/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@los/agent": "workspace:*",
    "@los/memory": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
