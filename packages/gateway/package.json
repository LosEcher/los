{
  "name": "@los/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/server.ts"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "maint": "tsx src/maintenance/index.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency 1 --experimental-test-coverage src/*.test.ts src/**/*.test.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.2.0",
    "@los/agent": "workspace:*",
    "@los/infra": "workspace:*",
    "@los/memory": "workspace:*",
    "fastify": "^5.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
