{
  "name": "los",
  "private": true,
  "description": "Lightweight Agent Execution + Memory Management Platform",
  "bin": {
    "los": "./bin/los"
  },
  "scripts": {
    "help": "./tools/los.sh help",
    "status": "./tools/los.sh status",
    "start": "./tools/los.sh start",
    "stop": "./tools/los.sh stop",
    "restart": "./tools/los.sh restart",
    "doctor": "./tools/los.sh doctor",
    "executor:help": "bash ./tools/executor.sh help",
    "executor:status": "bash ./tools/executor.sh status",
    "executor:start": "bash ./tools/executor.sh start",
    "executor:stop": "bash ./tools/executor.sh stop",
    "executor:restart": "bash ./tools/executor.sh restart",
    "executor:drain": "bash ./tools/executor.sh drain",
    "executor:promote": "bash ./tools/executor.sh promote",
    "executor:upgrade": "bash ./tools/executor.sh upgrade",
    "cli": "./bin/los",
    "dev": "turbo dev",
    "build": "turbo build",
    "check:contracts": "./tools/check-contracts.sh",
    "check:bypass": "./tools/check-state-machine-bypass.sh",
    "check": "turbo check && ./tools/check-structure.sh && ./tools/check-state-machine-bypass.sh && ./tools/check-contracts.sh",
    "gate": "./tools/ci-gate.sh",
    "pre-push": "./tools/ci-gate.sh",
    "_typecheck": "turbo check",
    "_test": "turbo test",
    "test": "turbo test",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
