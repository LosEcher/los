# los — Environment Configuration
#
# Config discovery order (highest to lowest):
#   1. CLI flags / process.env
#   2. .env file (this file, in working directory)
#   3. ~/.los/config.yaml (user profile)
#   4. /etc/los/config.yaml (system-wide)
#   5. Built-in defaults
#
# All values are optional — los auto-discovers providers from *_API_KEY env vars.

# ── Database ─────────────────────────────────────────────
# PostgreSQL is the only los persistence mode. A single-node install is the
# same mesh/cloud architecture with one active node.
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/los

# ── Server ───────────────────────────────────────────────
# SERVER_PORT=8080
# SERVER_HOST=127.0.0.1       # Use 0.0.0.0 if remote executors need to reach the gateway

# ── Auth ─────────────────────────────────────────────────
# When LOS_AUTH_ENABLED=true, every non-public gateway request must carry
# x-los-auth-token: <LOS_AUTH_TOKEN> (the access gate).
# LOS_AUTH_ENABLED=true
# LOS_AUTH_TOKEN=change-me
# Inspect the active local source without printing secrets: pnpm run auth:locate
# Rotate .env + matching ~/.weclaw config and sanitize local logs: pnpm run auth:rotate

# Operator privilege (second tier). Operator-only endpoints — operator steering
# (POST /sessions/:id/operator-events), the operator event stream
# (GET /operator/events/live), and security scans — additionally require
# x-los-operator-token: <LOS_OPERATOR_TOKEN> when auth is enabled. Bots
# (telegram-bot, wechat-bot) read this same env var and send the header on
# operator actions. When unset, operator access is disabled entirely.
# LOS_OPERATOR_TOKEN=change-me-operator

# ── WxPusher ingress ────────────────────────────────────
# Outbound push remains available with WXPUSHER_APP_TOKEN/WXPUSHER_UIDS.
# HARD GATE: keep inbound up-call disabled until every item below is enforced:
# - authenticated proxy injects x-los-wxpusher-proxy-secret and forwards only
#   to the loopback listener; the listener is never directly exposed;
# - proxy/LB access logs omit query strings (`$args`, `request_uri`, full URL),
#   and APM/tracing redacts the `token` query parameter;
# - the independent callback token has an owner and rotation procedure.
# Configure WxPusher with the complete URL:
#   https://example.com/wxpusher/wxpusher-callback?token=<LOS_WXPUSHER_CALLBACK_TOKEN>
# Rotate both callback secrets after suspected exposure or operator/access
# changes, and on the deployment's scheduled credential rotation cadence.
# WXPUSHER_UPCALL_ENABLED=1
# WXPUSHER_APP_ID=12345
# WXPUSHER_OPERATOR_UIDS=UID_operator_only
# WXPUSHER_CALLBACK_PROXY_SECRET=replace-with-at-least-32-random-bytes
# LOS_WXPUSHER_CALLBACK_TOKEN=replace-with-an-independent-32-byte-random-token
# WXPUSHER_CALLBACK_HOST=127.0.0.1
# WXPUSHER_CALLBACK_PORT=8900
# WXPUSHER_CALLBACK_URL=https://example.com/wxpusher
# WXPUSHER_CALLBACK_MAX_AGE_MS=300000
# WXPUSHER_CALLBACK_MAX_FUTURE_SKEW_MS=30000
# WXPUSHER_CALLBACK_MAX_BODY_BYTES=16384

# Telegram bot ingress. Both chat IDs and individual operator user IDs must be
# pre-authorized; /start never adds new identities. Webhook mode requires both
# TELEGRAM_WEBHOOK_URL (the public HTTPS base URL forwarded to the loopback
# listener) and a random secret of at least 32 characters.
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890,123456789
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_URL=https://telegram.example.com
# Generate: openssl rand -hex 32
# Rotate: replace TELEGRAM_WEBHOOK_SECRET, then restart telegram-bot; startup
# calls setWebhook with the new secret and invalidates deliveries using the old.
# TELEGRAM_WEBHOOK_SECRET=<64-character output from openssl rand -hex 32>

# ── Agent ────────────────────────────────────────────────
# AGENT_DEFAULT_PROVIDER=deepseek
# AGENT_DEFAULT_MODEL=deepseek-v4-flash
# AGENT_MAX_LOOPS=20
# AGENT_SANDBOX_MODE=workspace-write
# Storm breaker (ADR 0024): suppress repeated identical tool calls.
# LOS_STORM_WINDOW=6     # sliding-window size (recent tool-call signatures)
# LOS_STORM_THRESHOLD=3  # suppress the Nth identical call (N = threshold)

# ── Providers ────────────────────────────────────────────
# los auto-discovers providers from these env vars:
# DEEPSEEK_API_KEY=sk-xxx
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-xxx
#
# Or store in ~/.los/accounts/<name>.json (cc-switch pattern):
#   { "provider": "deepseek", "api_key": "sk-xxx", "model": "deepseek-v4-flash" }
#
# Local models auto-detected on standard ports:
#   Ollama (:11434), LM Studio (:1234), vLLM (:8000)

# ── Memory ───────────────────────────────────────────────
# MEMORY_FTS_ENABLED=true

# ── Branch-hygiene governance ────────────────────────────
# LOS_BRANCH_GOVERNANCE_PRIMARY_REMOTE=origin  # origin must point to Forgejo
# LOS_BRANCH_GOVERNANCE_MIRROR_REMOTE=github   # optional secondary mirror
# LOS_BRANCH_GOVERNANCE_MIRROR_SYNC=0          # opt in after mirror credentials/rules permit pushes
#   The branch_cleanup GA job prunes stale branches only on the primary remote.
#   When mirror sync is enabled, it fast-forwards mirror/main from primary/main.
#   LOS_BRANCH_GOVERNANCE_FORGEJO_SYNC remains a deprecated compatibility alias.

# ── Executor ─────────────────────────────────────────────
# EXECUTOR_ENABLED=false
# EXECUTOR_AGENT_KEY=  (auto-generated if not set; configure for multi-node setups)
# EXECUTOR_NODE_ID=node-1
# EXECUTOR_NODE_KIND=executor  (executor | ssh_target | ingress | proxy; defaults to executor)
# EXECUTOR_CONNECT_MODES=socks5,tailscale_ssh  (comma-separated, appended to agent_http+agent_http_ndjson)
# EXECUTOR_MESH_NODES=node1:8080,node2:8080
# GATEWAY_URL=http://<gateway-host>:8080  (remote executor heartbeat target)

# ── Profile ──────────────────────────────────────────────
# LOS_PROFILE=default
